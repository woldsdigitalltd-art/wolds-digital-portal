{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/run-scheduled-audits",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/run-review-monitor",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-uptime-alerts",
      "schedule": "0 * * * *"
    }
  ]
}
